## Build Logs (generated during development)
/logs/
GeneralsMD/logs/
Generals/logs/

# vcpkg artifacts (generated dependencies)
/vcpkg_installed/

# External reference repositories (large, don't commit)
# references/

# Release bundles
GeneralsX-macos-*.zip
GeneralsXZH-macos-*.zip
GeneralsX-linux-*.tar.gz
GeneralsXZH-linux-*.tar.gz

# flatpak build files (exclude staging/build dirs but track scripts and manifests)
.flatpak-builder/
flatpak/staging/
flatpak/*.flatpak

#tmp and log files on root folder
logs_*.zip
*.log
# iOS shell-app build products (XcodeGen regenerates the project from ios/project.yml)
ios/build/
ios/GeneralsXZH.xcodeproj/

# Android build artifacts (Gradle, local.properties, staged .so libs)
android/app/build/
android/.gradle/
android/local.properties
android/app/src/main/jniLibs/
*.apk
*.aab
