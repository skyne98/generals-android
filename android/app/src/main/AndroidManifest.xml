<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Vulkan + OpenGL ES (DXVK targets Vulkan; surface via SDL3) -->
    <uses-feature android:name="android.hardware.vulkan.level" android:required="true" />
    <uses-feature android:glEsVersion="0x00030000" android:required="false" />

    <!-- Touchscreen (the only input paradigm; no gamepad/keyboard required) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.Generals">

        <!--
          SDLActivity loads libmain.so (the engine, built by the android-vulkan
          preset as a shared lib) and calls SDL_main() — which is the engine's
          main() in GeneralsMD/Code/Main/SDL3Main.cpp (SDL3 renames main -> SDL_main).
        -->
        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode"
            android:exported="true"
            android:launchMode="singleInstance"
            android:screenOrientation="sensorLandscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
