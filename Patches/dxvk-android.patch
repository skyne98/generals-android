+  Rc<DxvkImage> DxvkUnboundResources::createImage(VkImageType type, uint32_t layers) {
+    const std::array<VkFormat, 2> viewFormats = {
+      VK_FORMAT_R32_UINT,
+      VK_FORMAT_R32_SFLOAT,
+    };
+
+    DxvkImageCreateInfo info;
+    info.type = type;
+    info.format = VK_FORMAT_R32_UINT;
+    info.flags = VK_IMAGE_CREATE_MUTABLE_FORMAT_BIT;
+    info.sampleCount = VK_SAMPLE_COUNT_1_BIT;
+    info.extent = { 1, 1, 1 };
+    info.numLayers = layers;
+    info.mipLevels = 1;
+    info.usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT
+               | VK_IMAGE_USAGE_SAMPLED_BIT
+               | VK_IMAGE_USAGE_STORAGE_BIT;
+    info.stages = VK_PIPELINE_STAGE_TRANSFER_BIT
+                | m_device->getShaderPipelineStages();
+    info.access = VK_ACCESS_SHADER_READ_BIT
+                | VK_ACCESS_SHADER_WRITE_BIT;
+    info.layout = VK_IMAGE_LAYOUT_GENERAL;
+    info.tiling = VK_IMAGE_TILING_OPTIMAL;
+    info.viewFormatCount = viewFormats.size();
+    info.viewFormats = viewFormats.data();
+    info.debugName = "Null image";
+
+    if (type == VK_IMAGE_TYPE_2D)
+      info.flags |= VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT;
+
+    return m_device->createImage(info, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
+  }
